---
import Layout from "../layouts/Layout.astro";
import bathtub1 from "../assets/images/bathtub-1.png";
---

<Layout
	title="Реставрация ванн немецким акрилом Fintex в Казахстане"
	description="Официальное представительство завода Fintex. Реставрация ванн премиальным немецким наливным акрилом. Честная гарантия 2 года. Закажите прямо сейчас!"
>
	<!-- Header / Navbar -->
	<header
		class="bg-white/90 backdrop-blur-md sticky top-0 z-50 border-b border-slate-200"
	>
		<div
			class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center flex-wrap"
		>
			<div class="text-2xl font-bold text-slate-800 tracking-tight">
				RestVanna <span class="text-blue-600">Fintex</span>
			</div>
			<a
				href="https://wa.me/77055606066"
				target="_blank"
				rel="noopener noreferrer"
				class="hidden sm:inline-flex items-center gap-2 text-slate-600 hover:text-emerald-600 font-medium transition-colors"
			>
				<span class="text-lg">📞 +7 (705) 560-60-66</span>
			</a>
		</div>
	</header>

	<main class="flex-grow">
		<!-- HERO SECTION -->
		<section
			class="relative bg-slate-900 text-white overflow-hidden py-16 sm:py-24"
		>
			<!-- Фоновое изображение или градиент -->
			<div
				class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-blue-900 opacity-90"
			>
			</div>
			<!-- Декоративные элементы -->
			<div
				class="absolute top-0 right-0 -mt-20 -mr-20 w-80 h-80 bg-blue-500 rounded-full blur-3xl opacity-20"
			>
			</div>
			<div
				class="absolute bottom-0 left-0 -mb-20 -ml-20 w-72 h-72 bg-emerald-500 rounded-full blur-3xl opacity-20"
			>
			</div>

			<div
				class="relative max-w-6xl mx-auto px-4 text-center sm:text-left flex flex-col sm:flex-row items-center gap-12"
			>
				<div class="flex-1 space-y-6">
					<div
						class="inline-block px-3 py-1 rounded-full bg-blue-500/20 border border-blue-400/30 text-blue-300 text-sm font-semibold mb-2"
					>
						Официальное представительство
					</div>
					<h1
						class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight"
					>
						Реставрация ванн премиальным немецким акрилом <span
							class="text-blue-400">Fintex</span
						>
					</h1>
					<p
						class="text-lg sm:text-xl text-slate-300 font-medium max-w-2xl bg-slate-800/40 p-4 rounded-xl border border-slate-700/50 backdrop-blur-sm shadow-lg"
					>
						Мы являемся официальным представительством завода <b
							>«Fintex»</b
						> в Казахстане. Именно поэтому мы даем <span
							class="text-emerald-400"
							>честную официальную гарантию 2 года</span
						> на отсутствие вздутий и трещин.
					</p>
					<div class="pt-4">
						<a
							href="https://wa.me/77055606066?text=%D0%97%D0%B4%D1%80%D0%B0%D0%B2%D1%81%D1%82%D0%B2%D1%83%D0%B9%D1%82%D0%B5!%20%D0%A5%D0%BE%D1%87%D1%83%20%D1%83%D0%B7%D0%BD%D0%B0%D1%82%D1%8C%20%D0%BF%D0%BE%D0%B4%D1%80%D0%BE%D0%B1%D0%BD%D0%B5%D0%B5%20%D0%BE%20%D1%80%D0%B5%D1%81%D1%82%D0%B0%D0%B2%D1%80%D0%B0%D1%86%D0%B8%D0%B8%20%D0%B2%D0%B0%D0%BD%D0%BD%D1%8B."
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center justify-center gap-2 px-8 py-4 w-full sm:w-auto text-lg font-bold text-white bg-emerald-600 hover:bg-emerald-500 rounded-xl shadow-xl shadow-emerald-500/30 hover:shadow-emerald-500/50 transform hover:-translate-y-1 transition-all"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="currentColor"
								><path
									d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 1.8 6.3L.1 23.9l5.8-1.5A11.95 11.95 0 0 0 12 24a12 12 0 0 0 0-24zm0 22A9.9 9.9 0 0 1 3.5 19.3L1.9 20l.7-1.6a9.9 9.9 0 1 1 9.4 3.6zm5.4-7.2c-.3-.1-1.8-.9-2-1-.3-.1-.5-.1-.7.1-.2.3-.8 1-1 1.2-.1.2-.3.3-.6.1s-1.3-.5-2.4-1.5c-.9-.8-1.5-1.8-1.7-2-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.3-.7-1.7-.9-2.3-.2-.6-.4-.5-.6-.5h-.5c-.2 0-.6.1-.9.4s-1.1 1.1-1.1 2.7 1.2 3.1 1.3 3.3 2.3 3.5 5.5 4.9c.8.3 1.4.5 1.8.6.8.3 1.5.2 2 .1.6-.1 1.8-.7 2-1.5.2-.8.2-1.4.1-1.5-.1-.2-.3-.3-.6-.4z"
								></path></svg
							>
							Написать в WhatsApp
						</a>
					</div>
				</div>
				<!-- Плейсхолдер для героя -->
				<div class="flex-1 w-full max-w-md hidden md:block">
					<div
						class="relative rounded-2xl overflow-hidden shadow-2xl border-4 border-slate-700/50 transform rotate-2 hover:rotate-0 transition-transform duration-500"
					>
						<img
							src={bathtub1.src}
							alt="Мастера в аккуратной рабочей одежде реставрируют ванну наливным акрилом. Интерьер ванной комнаты — типичный старый ремонт в стиле хрущевки, контраст новой белой ванны и старых стен"
							class="w-full h-auto object-cover"
						/>
						<div
							class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-slate-900/90 to-transparent p-6 pb-4"
						>
							<p class="text-white font-medium text-sm">
								Идеально белая поверхность без демонтажа
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- PRICING SECTION -->
		<section class="py-16 sm:py-24 bg-white relative">
			<div class="max-w-4xl mx-auto px-4">
				<div class="text-center mb-12">
					<h2
						class="text-3xl sm:text-4xl font-extrabold text-slate-800 mb-4"
					>
						Наши Цены
					</h2>
					<p class="text-lg text-slate-600 max-w-2xl mx-auto">
						Здравствуйте! Вас приветствует представительство
						германского завода <b>"Fintex"</b> в Казахстане. Прайс рассчитывается
						исходя из количества акрила на размер ванны.
					</p>
				</div>

				<div
					class="bg-slate-50 rounded-3xl p-6 sm:p-10 shadow-lg border border-slate-100"
				>
					<div class="text-center mb-8">
						<h3 class="text-2xl font-bold text-blue-700">
							Акрил Fintex Мрамор
						</h3>
						<span
							class="inline-block mt-2 px-4 py-1.5 bg-emerald-100 text-emerald-800 rounded-full text-sm font-bold shadow-sm"
							>+ 10 лет к сроку службы покрытия</span
						>
					</div>

					<!-- Pricing Cards -->
					<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
						<!-- Card 1 -->
						<div
							class="bg-white rounded-2xl p-6 flex flex-col items-center text-center shadow-md border border-slate-100 hover:shadow-xl hover:border-blue-200 transition-all transform hover:-translate-y-1"
						>
							<div
								class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mb-4"
							>
								<svg
									class="w-8 h-8 text-blue-500"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
									><path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M4 8h16M4 16h16"></path></svg
								>
							</div>
							<h4
								class="text-xl font-semibold text-slate-700 mb-2"
							>
								Ванна 1,2 м
							</h4>
							<p
								class="mt-auto text-3xl font-extrabold text-blue-600"
							>
								29.000 <span
									class="text-lg text-slate-400 font-medium"
									>тг</span>
							</p>
						</div>
						<!-- Card 2 -->
						<div
							class="bg-white rounded-2xl p-6 flex flex-col items-center text-center shadow-md border-2 border-blue-500 relative transform hover:-translate-y-1 transition-all md:-mt-4"
						>
							<div
								class="absolute -top-4 bg-blue-600 text-white px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider"
							>
								Хит продаж
							</div>
							<div
								class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mb-4"
							>
								<svg
									class="w-8 h-8 text-blue-600"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
									><path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M4 8h16M4 16h16"></path></svg
								>
							</div>
							<h4
								class="text-xl font-semibold text-slate-700 mb-2"
							>
								Ванна 1,5 м
							</h4>
							<p
								class="mt-auto text-4xl font-extrabold text-blue-600"
							>
								32.000 <span
									class="text-lg text-slate-400 font-medium"
									>тг</span>
							</p>
						</div>
						<!-- Card 3 -->
						<div
							class="bg-white rounded-2xl p-6 flex flex-col items-center text-center shadow-md border border-slate-100 hover:shadow-xl hover:border-blue-200 transition-all transform hover:-translate-y-1"
						>
							<div
								class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mb-4"
							>
								<svg
									class="w-8 h-8 text-blue-500"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
									><path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M4 8h16M4 16h16"></path></svg
								>
							</div>
							<h4
								class="text-xl font-semibold text-slate-700 mb-2"
							>
								Ванна 1,7 м
							</h4>
							<p
								class="mt-auto text-3xl font-extrabold text-blue-600"
							>
								34.000 <span
									class="text-lg text-slate-400 font-medium"
									>тг</span>
							</p>
						</div>
					</div>

					<div
						class="bg-orange-50 border-l-4 border-orange-400 p-4 rounded-r-lg"
					>
						<div class="flex">
							<div class="flex-shrink-0">
								<svg
									class="h-5 w-5 text-orange-400"
									viewBox="0 0 20 20"
									fill="currentColor"
									><path
										fill-rule="evenodd"
										d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
										clip-rule="evenodd"></path></svg
								>
							</div>
							<div class="ml-3">
								<p class="text-sm text-orange-800">
									<b>Важно:</b> В случае, если ванна реставрировалась
									ранее, к стоимости добавляется <strong
										>+ 10.000 тенге</strong
									> за снятие старого покрытия.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- GALLERY & CONTACT FORM SECTION -->
		<section class="py-16 sm:py-24 bg-slate-50 border-t border-slate-200">
			<div class="max-w-6xl mx-auto px-4">
				<div
					class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center"
				>
					<!-- Gallery Slider (CSS Only for simplicity, scroll-snap) -->
					<div class="order-2 lg:order-1">
						<h3
							class="text-2xl sm:text-3xl font-bold text-slate-800 mb-6 text-center lg:text-left"
						>
							Наши работы
						</h3>

						<div
							class="relative max-w-full overflow-hidden rounded-2xl shadow-xl bg-white border border-slate-100"
						>
							<div
								class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide"
								style="scrollbar-width: none; -ms-overflow-style: none;"
							>
								<!-- Slide 1 -->
								<div
									class="flex-none w-full snap-center relative aspect-[4/3]"
								>
									<!-- Image Prompt: Мастера в аккуратной рабочей одежде реставрируют ванну наливным акрилом. Интерьер ванной комнаты — типичный старый ремонт в стиле хрущевки, контраст новой белой ванны и старых стен -->
									<img
										src={bathtub1.src}
										alt="Процесс реставрации ванны акрилом Fintex"
										class="w-full h-full object-cover"
									/>
									<div
										class="absolute bottom-4 left-4 bg-white/90 backdrop-blur-sm px-4 py-2 rounded-lg shadow-sm font-medium text-slate-800 text-sm"
									>
										До / После
									</div>
								</div>

								<!-- Slide 2 -->
								<div
									class="flex-none w-full snap-center relative aspect-[4/3]"
								>
									<img
										src="https://placehold.co/800x600/cbd5e1/334155?text=Gallery+Image+2"
										alt="Белоснежная отреставрированная ванна"
										class="w-full h-full object-cover"
									/>
									<div
										class="absolute bottom-4 left-4 bg-white/90 backdrop-blur-sm px-4 py-2 rounded-lg shadow-sm font-medium text-slate-800 text-sm"
									>
										Ванна 1.5м Мрамор
									</div>
								</div>

								<!-- Slide 3 -->
								<div
									class="flex-none w-full snap-center relative aspect-[4/3]"
								>
									<img
										src="https://placehold.co/800x600/94a3b8/1e293b?text=Gallery+Image+3"
										alt="Мастер наливает акрил на края ванны"
										class="w-full h-full object-cover"
									/>
									<div
										class="absolute bottom-4 left-4 bg-white/90 backdrop-blur-sm px-4 py-2 rounded-lg shadow-sm font-medium text-slate-800 text-sm"
									>
										Процесс налива
									</div>
								</div>
							</div>

							<!-- Scroll Hint for mobile -->
							<div
								class="absolute bottom-4 right-4 bg-slate-800/60 backdrop-blur-sm text-white px-3 py-1.5 rounded-full text-xs flex items-center gap-1 sm:hidden"
							>
								<span>Листайте</span>
								<svg
									class="w-4 h-4"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
									><path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M14 5l7 7m0 0l-7 7m7-7H3"
									></path></svg
								>
							</div>
						</div>
					</div>

					<!-- Contact Form CTA -->
					<div class="order-1 lg:order-2">
						<div
							class="bg-white rounded-3xl p-8 sm:p-10 shadow-2xl border border-slate-100 relative overflow-hidden"
						>
							<div
								class="absolute top-0 right-0 -mt-10 -mr-10 w-40 h-40 bg-blue-50 rounded-full blur-2xl opacity-50 z-0"
							>
							</div>

							<div class="relative z-10">
								<h3
									class="text-3xl font-extrabold text-slate-800 mb-4"
								>
									Нужна консультация?
								</h3>
								<p class="text-slate-600 mb-8 text-lg">
									Оставьте свой номер, и мы перезвоним вам для
									детальной консультации и расчета стоимости.
								</p>

								<form id="contactForm" class="space-y-5">
									<div>
										<label
											for="phone"
											class="block text-sm font-semibold text-slate-700 mb-2"
											>Ваш телефон</label
										>
										<div class="relative">
											<div
												class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none"
											>
												<span
													class="text-slate-400 text-lg"
													>📞</span
												>
											</div>
											<input
												type="tel"
												id="phone"
												name="phone"
												required
												placeholder="+7 (___) ___-__-__"
												class="block w-full pl-12 pr-4 py-4 bg-slate-50 border border-slate-200 rounded-xl text-slate-800 text-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all outline-none"
											/>
										</div>
									</div>

									<button
										type="submit"
										class="w-full flex justify-center items-center py-4 px-6 border border-transparent rounded-xl shadow-lg text-lg font-bold text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transform hover:-translate-y-0.5 transition-all"
									>
										Оставить заявку
									</button>
								</form>

								<p
									class="mt-4 text-xs text-center text-slate-400"
								>
									Нажимая кнопку, вы соглашаетесь с политикой
									конфиденциальности. Мы не передаем данные
									третьим лицам.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer
		class="bg-slate-900 text-slate-400 py-8 text-center border-t border-slate-800"
	>
		<div class="max-w-6xl mx-auto px-4">
			<p class="font-medium">
				© {new Date().getFullYear()} RestVanna Fintex Казахстан. Все права
				защищены.
			</p>
		</div>
	</footer>
</Layout>

<script>
	// Форматирование ввода телефона (простая маска)
	const phoneInput = document.getElementById("phone") as HTMLInputElement;

	if (phoneInput) {
		phoneInput.addEventListener("input", function (e) {
			let x = this.value
				.replace(/\D/g, "")
				.match(/(\d{0,1})(\d{0,3})(\d{0,3})(\d{0,2})(\d{0,2})/);

			if (!x) return;

			// Формат: +7 (XXX) XXX-XX-XX
			// Если начинается с 7, 8 или если введено хотя бы 1 цифра
			if (x[1]) {
				let formatted = "+7 ";

				// Если ввели 8 или 7 сначала, не дублируем
				const numStartsWith7or8 = x[1] === "7" || x[1] === "8";

				if (numStartsWith7or8 && !x[2]) {
					this.value = "+7 ";
					return;
				}

				// Учитываем, если код был введён с 7
				let idx2 = numStartsWith7or8 ? 2 : 1;
				let idx3 = numStartsWith7or8 ? 3 : 2;
				let idx4 = numStartsWith7or8 ? 4 : 3;
				let idx5 = numStartsWith7or8 ? 5 : 4;

				let output = "+7 ";
				if (x[idx2]) output += "(" + x[idx2];
				if (x[idx3]) output += ") " + x[idx3];
				if (x[idx4]) output += "-" + x[idx4];
				if (x[idx5]) output += "-" + x[idx5];

				this.value = output;
			}
		});

		// Отправка формы с редиректом в WhatsApp
		const form = document.getElementById("contactForm");
		form?.addEventListener("submit", (e) => {
			e.preventDefault();
			const phone = phoneInput.value;
			if (phone.length < 10) {
				alert("Пожалуйста, введите корректный номер телефона");
				return;
			}

			const message = encodeURIComponent(
				`Здравствуйте! Оставляю заявку с сайта на консультацию. Мой номер: ${phone}`,
			);
			const whatsappUrl = `https://wa.me/77055606066?text=${message}`;

			window.open(whatsappUrl, "_blank");

			// Optional: Очистка формы после отправки
			phoneInput.value = "";
		});
	}
</script>

<style>
	/* Убираем скроллбар для слайдера */
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
</style>
