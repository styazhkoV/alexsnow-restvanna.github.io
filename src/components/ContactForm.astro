---
// Contact Form — captures phone number and redirects to WhatsApp
---

<section id="contact" class="relative py-20 sm:py-28 overflow-hidden">
  <div class="absolute inset-0 bg-slate-900"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-sky-500/50 to-transparent"></div>
  <!-- Decorative -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-sky-500/5 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-xl mx-auto px-4 sm:px-6">
    <div class="rounded-3xl bg-slate-800/50 border border-slate-700/50 p-8 sm:p-10 backdrop-blur-sm shadow-2xl">
      <!-- Header -->
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-green-500/10 mb-5">
          <svg class="w-7 h-7 text-green-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </div>
        <h2 class="text-2xl sm:text-3xl font-bold mb-3">Оставьте заявку</h2>
        <p class="text-slate-400">
          Укажите ваш номер, и мы перезвоним для бесплатной консультации
        </p>
      </div>

      <!-- Form -->
      <form id="contact-form" class="space-y-4">
        <div>
          <label for="phone" class="block text-sm font-medium text-slate-300 mb-2">Номер телефона</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="+7 (___) ___-__-__"
            required
            class="w-full px-5 py-4 bg-slate-900/80 border border-slate-600 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent transition-all duration-300 text-lg"
          />
        </div>
        <button
          type="submit"
          class="w-full py-4 bg-gradient-to-r from-green-500 to-emerald-500 text-white font-bold text-lg rounded-xl shadow-lg shadow-green-500/25 hover:from-green-400 hover:to-emerald-400 hover:shadow-green-400/30 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
        >
          Оставить заявку
        </button>
      </form>

      <!-- Privacy note -->
      <p class="text-center text-xs text-slate-500 mt-5">
        Нажимая кнопку, вы соглашаетесь на обработку персональных данных
      </p>
    </div>

    <!-- Secondary CTA -->
    <div class="text-center mt-10">
      <p class="text-slate-400 mb-4">Или напишите нам напрямую:</p>
      <a
        href="https://wa.me/77055606066"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-green-400 font-semibold hover:text-green-300 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        +7 (705) 560-60-66
      </a>
    </div>
  </div>
</section>

<script>
  // Form submission handler — redirect to WhatsApp with pre-filled message
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const phoneInput = document.getElementById('phone') as HTMLInputElement;
    const phone = phoneInput?.value.trim();

    if (!phone) {
      alert('Пожалуйста, введите номер телефона');
      return;
    }

    const message = encodeURIComponent(
      `Здравствуйте! Оставляю заявку на реставрацию ванны.\nМой номер: ${phone}\nПерезвоните мне, пожалуйста.`
    );

    window.open(`https://wa.me/77055606066?text=${message}`, '_blank');

    // Show success feedback
    const btn = (e.target as HTMLFormElement).querySelector('button[type="submit"]');
    if (btn) {
      btn.textContent = '✓ Заявка отправлена!';
      btn.classList.add('from-emerald-600', 'to-green-600');
      setTimeout(() => {
        btn.textContent = 'Оставить заявку';
        btn.classList.remove('from-emerald-600', 'to-green-600');
      }, 3000);
    }
  });
</script>
