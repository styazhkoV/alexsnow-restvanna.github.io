---
// Gallery Section — work examples slider (CSS-only)
// Placeholder images — replace with real photos
const slides = [
  {
    id: 1,
    alt: 'Мастера в аккуратной рабочей одежде реставрируют ванну наливным акрилом. Интерьер ванной комнаты — типичный старый ремонт в стиле хрущевки, контраст новой белой ванны и старых стен',
    caption: 'До и после реставрации',
    gradient: 'from-sky-600 to-cyan-500',
  },
  {
    id: 2,
    alt: 'Мастера в аккуратной рабочей одежде реставрируют ванну наливным акрилом. Интерьер ванной комнаты — типичный старый ремонт в стиле хрущевки, контраст новой белой ванны и старых стен',
    caption: 'Процесс заливки акрила',
    gradient: 'from-emerald-600 to-teal-500',
  },
  {
    id: 3,
    alt: 'Мастера в аккуратной рабочей одежде реставрируют ванну наливным акрилом. Интерьер ванной комнаты — типичный старый ремонт в стиле хрущевки, контраст новой белой ванны и старых стен',
    caption: 'Готовая работа — как новая',
    gradient: 'from-violet-600 to-purple-500',
  },
  {
    id: 4,
    alt: 'Мастера в аккуратной рабочей одежде реставрируют ванну наливным акрилом. Интерьер ванной комнаты — типичный старый ремонт в стиле хрущевки, контраст новой белой ванны и старых стен',
    caption: 'Результат через 2 года',
    gradient: 'from-amber-600 to-orange-500',
  },
];
---

<section id="gallery" class="relative py-20 sm:py-28 overflow-hidden">
  <div class="absolute inset-0 bg-slate-950"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/50 to-transparent"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-emerald-400 font-semibold text-sm uppercase tracking-wider mb-3">Портфолио</p>
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">Наши работы</h2>
      <p class="text-slate-400 max-w-xl mx-auto">
        Примеры реставрации ванн акрилом Fintex Мрамор. Каждый проект — как новая ванна.
      </p>
    </div>

    <!-- Slider container -->
    <div class="gallery-slider relative">
      <div class="flex gap-4 sm:gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-6 -mx-4 px-4 sm:mx-0 sm:px-0 scrollbar-hide">
        {slides.map((slide) => (
          <div class="flex-shrink-0 w-72 sm:w-80 snap-center">
            <div class={`relative aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br ${slide.gradient} group`}>
              <!-- Placeholder for real image -->
              <!-- Replace this div with <img> tag using real photos -->
              <div class="absolute inset-0 flex items-center justify-center p-6">
                <div class="text-center">
                  <svg class="w-16 h-16 text-white/30 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
                  </svg>
                  <p class="text-white/50 text-sm">{slide.alt}</p>
                </div>
              </div>
              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300"></div>
            </div>
            <p class="mt-3 text-sm text-slate-400 text-center font-medium">{slide.caption}</p>
          </div>
        ))}
      </div>

      <!-- Scroll hint -->
      <div class="flex items-center justify-center gap-2 mt-4 text-slate-500 text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        Листайте
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  /* Hide scrollbar for the slider */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
