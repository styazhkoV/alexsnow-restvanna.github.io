---
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
---

<section class="blog">
  <h2>Блог</h2>
  <div class="blog-list">
    {posts.map((post) => (
      <article class="blog-item">
        <h3>{post.data.title}</h3>
        <p>{post.data.description}</p>
        <small>{post.data.pubDate.toLocaleDateString("ru-RU")}</small>
      </article>
    ))}
  </div>
</section>

<style>
  .blog {
    padding: 2rem;
    color: #fff;
  }
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .blog-item {
    background: rgba(255, 255, 255, 0.05);
    padding: 1rem;
    border-radius: 8px;
  }
  .blog-item h3 {
    margin: 0 0 0.5rem;
  }
  .blog-item small {
    color: #aaa;
  }
</style>
